<?xml version='1.0' encoding='utf-8'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="fr3">

  <xacro:include filename="$(find franka_fr3_description)/robots/common/franka_robot.xacro"/>

  <!--
    DEPRECATION NOTICE
    argument arm_id is no longer supported and will be removed in the future.
    This argument is ignored.
  -->
  <xacro:arg name="arm_id" default="fr3" />
  <xacro:arg name="arm_prefix" default="" /> <!-- The prefix of the robot -->
  <xacro:arg name="no_prefix" default="false"/> <!-- Don't print a prefix for joints, visuals, and links? -->
  <xacro:arg name="hand" default="true" /> <!-- Should an end-effector be mounted at the flange?" -->
  <xacro:arg name="ee_id" default="franka_hand" /> <!-- Which end-effector would be mounted at the flange?" -->
  <xacro:arg name="special_connection" default="" /> <!-- Where is the end-effector connected to, if different from the robot flange?  -->
  <xacro:arg name="xyz_ee" default="0 0 0" /> <!-- Position offset between ee and parent frame -->
  <xacro:arg name="rpy_ee" default= "0 0 ${-pi/4}" /> <!-- Rotation offset between ee and parent frame -->
  <xacro:arg name="tcp_xyz" default="0 0 0.1034" /> <!-- Position offset between ee frame and tcp frame -->
  <xacro:arg name="tcp_rpy" default="0 0 0" /> <!-- Rotation offset between ee frame and tcp frame -->
  <xacro:arg name="safety_distance" default="0.03" /> <!-- Safety distance for the collision capsules -->
  <xacro:arg name="with_sc" default="false" /> <!-- Should self-collision be enabled? -->
  <xacro:arg name="ros2_control" default="false" /> <!-- Is the robot being controlled with ros2_control?" -->
  <xacro:arg name="robot_ip" default="" /> <!-- IP address or hostname of the robot" -->
  <xacro:arg name="use_fake_hardware" default="false" /> <!-- Should a fake hardware be used? -->
  <xacro:arg name="fake_sensor_commands" default="false" /> <!-- Should fake sensors be used? -->
  <xacro:arg name="gazebo" default="false" /> <!-- Should the robot be spawned in Gazebo?" -->
  <xacro:arg name="gazebo_effort" default="false" /> <!-- Should the robot be spawned in Gazebo with effort interfaces?" -->
  <xacro:arg name="description_pkg" default="franka_fr3_description" /> <!-- Name of the description package -->
  <xacro:arg name="controllers_yaml" default="$(find franka_fr3_moveit_config)/config/gazebo_controllers.yaml" /> <!-- Path to the controllers yaml file for Gazebo ros2_control plugin -->

  <!-- Append an underscore to the user-provided prefix, if non-empty. -->
  <xacro:property name="prefix" value="$(arg arm_prefix)"/>
  <xacro:property name="modified_prefix" value="${prefix + '_' if prefix else ''}"/>

  <!-- Load the robot description (fr3 mainpulator) with the provided arguments. -->
  <xacro:franka_robot arm_id="fr3"
                      joint_limits="${xacro.load_yaml('$(find franka_fr3_description)/robots/fr3/joint_limits.yaml')}"
                      inertials="${xacro.load_yaml('$(find franka_fr3_description)/robots/fr3/inertials.yaml')}"
                      kinematics="${xacro.load_yaml('$(find franka_fr3_description)/robots/fr3/kinematics.yaml')}"
                      accelerometer_config="${xacro.load_yaml('$(find franka_fr3_description)/robots/fr3/accelerometers.yaml')}"
                      dynamics="${xacro.load_yaml('$(find franka_fr3_description)/robots/fr3/dynamics.yaml')}"
                      gazebo="$(arg gazebo)"
                      hand="$(arg hand)"
                      ee_id="$(arg ee_id)"
                      special_connection="$(arg special_connection)"
                      xyz_ee="$(arg xyz_ee)"
                      rpy_ee="$(arg rpy_ee)"
                      tcp_xyz="$(arg tcp_xyz)"
                      tcp_rpy="$(arg tcp_rpy)"
                      safety_distance="$(arg safety_distance)"
                      with_sc="$(arg with_sc)"
                      ros2_control="$(arg ros2_control)"
                      robot_ip="$(arg robot_ip)"
                      use_fake_hardware="$(arg use_fake_hardware)"
                      fake_sensor_commands="$(arg fake_sensor_commands)"
                      gazebo_effort="$(arg gazebo_effort)"
                      no_prefix="$(arg no_prefix)"
                      arm_prefix="${modified_prefix}"
                      description_pkg="$(arg description_pkg)"
                      controllers_yaml="$(arg controllers_yaml)"
                      connected_to= "base">
  </xacro:franka_robot>

  <!-- ============================================ -->
  <!-- RealSense D435 Depth Camera on End-Effector  -->
  <!-- ============================================ -->

  <!-- Camera link with visual mesh from realsense2_description -->
  <link name="realsense_d435">
    <visual>
      <geometry>
        <mesh filename="package://realsense2_description/meshes/d435.dae"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.09 0.025 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.072"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
    </inertial>
  </link>

  <!-- Optical frame (Z forward, X right, Y down) for proper image orientation -->
  <link name="realsense_d435_optical_frame"/>

  <!-- Mount camera on fr3_hand: offset forward(+X) and up(+Z), tilted 30° down -->
  <joint name="realsense_joint" type="fixed">
    <parent link="fr3_hand"/>
    <child link="realsense_d435"/>
    <origin xyz="0.04 0 0.04" rpy="0 0 ${pi/2}"/>
  </joint>

  <!-- Optical frame transform: rotate from camera body to optical convention -->
  <joint name="realsense_optical_joint" type="fixed">
    <parent link="realsense_d435"/>
    <child link="realsense_d435_optical_frame"/>
    <!-- <origin xyz="0.04 0 0.04" rpy="${-pi/2} 0 ${-pi/2}"/> -->
    <origin xyz="0.04 0 0.04" rpy="${pi} ${pi} 0"/>
  </joint>

  <!-- Gazebo: Depth Camera Sensor -->
  <gazebo reference="realsense_d435">
    <sensor name="d435_depth" type="depth_camera">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>30</update_rate>
      <topic>camera/depth/image</topic>
      <gz_frame_id>realsense_d435_optical_frame</gz_frame_id>
      <camera>
        <horizontal_fov>1.211</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R_FLOAT32</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <!-- Gazebo: RGB Camera Sensor -->
  <gazebo reference="realsense_d435">
    <sensor name="d435_color" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>30</update_rate>
      <topic>camera/color/image</topic>
      <gz_frame_id>realsense_d435_optical_frame</gz_frame_id>
      <camera>
        <horizontal_fov>1.211</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>RGB_INT8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

</robot>
